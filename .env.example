# IBM Enterprise IT Help Desk Copilot — V3
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# IBM Cloud IAM — used for watsonx.ai token exchange
IBM_CLOUD_API_KEY=

# OpenSearch cluster
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=true
# v2 index names match ibm/granite-embedding-278m-multilingual (768-dim).
# Do NOT point these at v1 indexes built with a different embedding model.
OPENSEARCH_INDEX_CHUNKS=knowledge_chunks_v2
OPENSEARCH_INDEX_DOCS=knowledge_documents_v2
# Must equal the output dimension of WATSONX_EMBEDDING_MODEL_ID.
# ibm/granite-embedding-278m-multilingual → 768
# ibm/granite-embedding-107m-multilingual → 384
# Changing this requires dropping and recreating the index with create_index.py.
OPENSEARCH_EMBEDDING_DIM=768

# watsonx.ai — verify model IDs in your account/region before setting these.
# Do not use legacy Slate embedding IDs unless their lifecycle and regional
# availability have been verified in the target watsonx.ai account.
# Confirmed available in us-south: ibm/granite-embedding-278m-multilingual (768-dim)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_EMBEDDING_MODEL_ID=ibm/granite-embedding-278m-multilingual
WATSONX_CHAT_MODEL_ID=
WATSONX_CHAT_MAX_TOKENS=2048
WATSONX_CHAT_TEMPERATURE=0.0
WATSONX_RERANK_MODEL_ID=

# IBM Cloud Object Storage
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_BUCKET=
COS_API_KEY=

# IBM Documentation crawler and bounded live retrieval — required for network requests.
# Use a real monitored team contact; network operations reject an anonymous UA.
IBM_DOCS_USER_AGENT=IBM-IT-Helpdesk-DocsCrawler/1.0 contact@example.com
IBM_DOCS_DATA_DIR=~/.local/share/it-helpdesk/ibm-docs-crawler
IBM_DOCS_DELAY_SECONDS=1.5
IBM_DOCS_TIMEOUT_SECONDS=30
IBM_DOCS_MAX_RETRIES=4
IBM_DOCS_MAX_RESPONSE_BYTES=20000000
IBM_DOCS_MAX_CHUNKS_PER_DOCUMENT=250
IBM_DOCS_VALIDATE_PUBLIC_DNS=true

# FastAPI — random secret string sent by Orchestrate in X-API-Key header
# Generate with: openssl rand -hex 32
API_KEY_SECRET=
PUBLIC_API_BASE_URL=

# Feature flags
ENABLE_RERANKER=false
ENABLE_ADAPTIVE_RETRIEVAL=false
ENABLE_LIVE_IBM_DOCS=false
ENABLE_LIVE_OFFICIAL_SOURCES=false
ENABLE_LIVE_DOCS_INDEXING=false
ENABLE_LIVE_WEB_SEARCH=false

# Metadata-first + bounded live IBM Docs retrieval
LIVE_DOCS_INITIAL_PAGES=3
LIVE_DOCS_MAX_PAGES=5
LIVE_DOCS_RELATED_DEPTH=1
LIVE_DOCS_CONCURRENCY=3
LIVE_DOCS_CACHE_TTL_SECONDS=86400
LIVE_DOCS_CATALOG_CANDIDATES=30
LIVE_DOCS_EVIDENCE_CHUNKS=10
# Required before enabling background indexing; use explicitly reviewed names.
LIVE_DOCS_CHUNKS_INDEX=knowledge_chunks_ibm_docs_staging_v2
LIVE_DOCS_DOCS_INDEX=knowledge_documents_ibm_docs_staging_v2

# Optional official-domain web search. Run
# `.venv/bin/python scripts/configure_live_web_search.py` to configure the
# OpenAI provider without exposing the API key in shell history.
LIVE_WEB_SEARCH_API_KEY=
LIVE_WEB_SEARCH_PROVIDER=tavily
LIVE_WEB_SEARCH_ENDPOINT=https://api.tavily.com/search
LIVE_WEB_SEARCH_MODEL=gpt-5.5
LIVE_WEB_SEARCH_ALLOWED_DOMAINS=www.ibm.com,newsroom.ibm.com,support.ibm.com,cloud.ibm.com,redbooks.ibm.com,docs.redhat.com,access.redhat.com,developers.redhat.com
LIVE_WEB_SEARCH_TIMEOUT_SECONDS=30
LIVE_WEB_SEARCH_MAX_RESULTS=5
LIVE_WEB_SEARCH_CONTENT_CHARS=4000
LIVE_WEB_SEARCH_ANSWER_CANDIDATES=3
LIVE_WEB_SEARCH_DEPTH=advanced
LIVE_WEB_SEARCH_QUERY_VARIANTS=2

# Retrieval tuning
RRF_K=60

# Logging
LOG_LEVEL=INFO
