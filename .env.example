# OpenShift & SNO Technical Support Copilot — V3
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# IBM Cloud IAM — used for watsonx.ai token exchange
IBM_CLOUD_API_KEY=

# OpenSearch cluster
OPENSEARCH_URL=https://your-opensearch-host:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX_CHUNKS=knowledge_chunks_v1
OPENSEARCH_INDEX_DOCS=knowledge_documents_v1

# watsonx.ai — verify model IDs in your account before setting these
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_EMBEDDING_MODEL_ID=
WATSONX_CHAT_MODEL_ID=
WATSONX_RERANK_MODEL_ID=

# IBM Cloud Object Storage
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_BUCKET=
COS_API_KEY=

# FastAPI — random secret string sent by Orchestrate in X-API-Key header
# Generate with: openssl rand -hex 32
API_KEY_SECRET=

# Feature flags
ENABLE_RERANKER=false

# Retrieval tuning
RRF_K=60

# Logging
LOG_LEVEL=INFO
