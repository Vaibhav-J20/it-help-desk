# IBM Enterprise IT Help Desk Copilot — V3
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# IBM Cloud IAM — used for watsonx.ai token exchange
IBM_CLOUD_API_KEY=

# OpenSearch cluster
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_VERIFY_CERTS=true
# v2 index names match ibm/granite-embedding-278m-multilingual (768-dim).
# Do NOT point these at v1 indexes built with a different embedding model.
OPENSEARCH_INDEX_CHUNKS=knowledge_chunks_v2
OPENSEARCH_INDEX_DOCS=knowledge_documents_v2
# Must equal the output dimension of WATSONX_EMBEDDING_MODEL_ID.
# ibm/granite-embedding-278m-multilingual → 768
# ibm/granite-embedding-107m-multilingual → 384
# Changing this requires dropping and recreating the index with create_index.py.
OPENSEARCH_EMBEDDING_DIM=768

# watsonx.ai — verify model IDs in your account/region before setting these.
# ibm/slate-125m-english-rtrvr-v2 is WITHDRAWN (2026-08-08) — do NOT use.
# Confirmed available in us-south: ibm/granite-embedding-278m-multilingual (768-dim)
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_EMBEDDING_MODEL_ID=ibm/granite-embedding-278m-multilingual
WATSONX_CHAT_MODEL_ID=
WATSONX_RERANK_MODEL_ID=

# IBM Cloud Object Storage
COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
COS_BUCKET=
COS_API_KEY=

# FastAPI — random secret string sent by Orchestrate in X-API-Key header
# Generate with: openssl rand -hex 32
API_KEY_SECRET=

# Feature flags
ENABLE_RERANKER=false

# Retrieval tuning
RRF_K=60

# Logging
LOG_LEVEL=INFO
