# IBM IT Help Desk Chatbot — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# IBM Cloud API key (used for both Discovery auth and IAM token exchange for Watsonx.ai)
IBM_CLOUD_API_KEY=

# Watson Discovery v2
DISCOVERY_URL=https://api.{region}.discovery.watson.cloud.ibm.com
DISCOVERY_PROJECT_ID=
DISCOVERY_COLLECTION_ID=

# Watsonx.ai
WATSONX_PROJECT_ID=
WATSONX_REGION=us-south
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# FastAPI server auth — the secret that Orchestrate sends in the X-API-Key header
# Set this to any strong random string (e.g. openssl rand -hex 32)
API_KEY_SECRET=
